# agentscope daemon config (./agentscope.yaml). Optional — missing file is OK.

# Peer overrides: force a comm-type label for already-tracked agents' traffic.
peers:
  # "10.0.0.2:8080":      "Agent↔Agent"
  # "ollama.local:11434": "Agent↔Model"
  # "my-mcp-server:3000": "Agent↔MCP"

# Exact-match SNI / Host. Merged on top of detector.go builtins.
llm_hostnames:
  # - api.openai.com
  # - api.anthropic.com

# Glob-style ('*' matches one DNS label, no dots).
llm_hostname_patterns:
  # - "*.openai.azure.com"
  # - "bedrock-runtime.*.amazonaws.com"

# "<METHOD> <path-prefix>". Plaintext only — TLS hides the path.
llm_http_paths:
  # - "POST /v1/chat/completions"
  # - "POST /api/generate"
